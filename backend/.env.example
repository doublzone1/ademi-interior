# Какой AI-провайдер использовать:
#   pollinations — БЕСПЛАТНО, без регистрации (по умолчанию)
#   replicate    — платный, лучшее качество с сохранением геометрии комнаты
AI_PROVIDER=pollinations

PORT=5000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Нужен только если AI_PROVIDER=replicate.
# Получить: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_your_token_here

# Опционально: ключ imgbb для загрузки фото на CDN при работе с Pollinations.
# Без него Pollinations генерирует только по текстовому промпту (без фото комнаты).
# Получить бесплатно: https://api.imgbb.com/
# IMGBB_API_KEY=your_imgbb_key_here
